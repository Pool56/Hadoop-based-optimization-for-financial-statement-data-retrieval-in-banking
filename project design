1. Spark configuration optimization
config or spark_config.py
from pyspark.sql import SparkSession

def get_spark_session(app_name="FinancialOptimization"):

    spark = (
        SparkSession.builder
        .appName(app_name)
        .config("spark.sql.adaptive.enabled", "true")  # AQE
        .config("spark.sql.adaptive.coalescePartitions.enabled", "true")
        .config("spark.sql.adaptive.skewJoin.enabled", "true")
        .config("spark.sql.shuffle.partitions", "200")
        .config("spark.sql.autoBroadcastJoinThreshold", "104857600")  # 100MB
        .config("spark.sql.parquet.filterPushdown", "true")
        .config("spark.sql.inMemoryColumnarStorage.compressed", "true")
        .config("spark.sql.execution.arrow.pyspark.enabled", "true")
        .enableHiveSupport()
        .getOrCreate()
    )
2. Data ingestion
from config.spark_config import get_spark_session
from pyspark.sql.functions import col, year, quarter

spark = get_spark_session("IngestFinancialStatements")

# Load raw CSV extract from Core Banking
raw_df = spark.read \
    .option("header", "true") \
    .option("inferSchema", "true") \
    .csv("/data/raw/financial_statements.csv")

# Transformations
transformed_df = raw_df \
    .withColumn("year", year(col("report_date"))) \
    .withColumn("quarter", quarter(col("report_date"))) \
    .select(
        "account_id",
        "customer_id",
        "statement_type",
        "amount",
        "currency",
        "branch",
        "year",
        "quarter"
    )

# Write as partitioned Parquet (Optimization #1)
transformed_df.write \
    .mode("overwrite") \
    .partitionBy("year", "quarter", "branch") \
    .parquet("/data/curated/financial_statements")

spark.stop()

3. Use of bucketing for faster joins
# Used when frequently joining financial statements with customer master data.
transformed_df.write \
    .bucketBy(50, "customer_id") \
    .sortBy("customer_id") \
    .mode("overwrite") \
    .saveAsTable("bank.financial_statements_bucketed")

4. Optimized financial query job
from config.spark_config import get_spark_session
from pyspark.sql.functions import sum as _sum

spark = get_spark_session("QueryFinancialStatements")

# Load partitioned dataset
financial_df = spark.read.parquet("/data/curated/financial_statements")

# Predicate Pushdown (Optimization #2)
filtered_df = financial_df.filter(
    (financial_df.year == 2025) &
    (financial_df.statement_type == "BALANCE_SHEET")
)

# Cache frequently used dataset (Optimization #3)
filtered_df.cache()

# Aggregation
result = filtered_df.groupBy("branch") \
    .agg(_sum("amount").alias("total_assets"))

result.show()

spark.stop()

5. Broadcast join optimization
from pyspark.sql.functions import broadcast

branch_df = spark.read.parquet("/data/dim/branch_master")

optimized_join = filtered_df.join(
    broadcast(branch_df),
    "branch",
    "inner"
)

